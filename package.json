{
  "name": "wechat-ai-assistant",
  "version": "1.6.1",
  "description": "WeChat AI Assistant Desktop",
  "main": "src/main/index.js",
  "homepage": "https://github.com/byteD-x/wechat-bot",
  "repository": {
    "type": "git",
    "url": "https://github.com/byteD-x/wechat-bot.git"
  },
  "bugs": {
    "url": "https://github.com/byteD-x/wechat-bot/issues"
  },
  "scripts": {
    "start": "electron .",
    "dev": "chcp 65001 && electron . --dev",
    "test:main": "node --test tests\\update-manager.test.cjs tests\\main-shared-config.test.cjs tests\\main-ipc-security.test.cjs && node tests\\node\\test_backend_idle_controller.js",
    "test": "npm run test:main && npm run test:renderer",
    "test:renderer": "node --test tests\\node\\costs_page_split_helpers.test.mjs tests\\node\\dashboard_renderer_helpers.test.mjs tests\\node\\dashboard_page_split_helpers.test.mjs tests\\node\\logs_page_split_helpers.test.mjs tests\\node\\messages_page_split_helpers.test.mjs tests\\node\\settings_form_codec.test.mjs tests\\node\\frontend_engineering_helpers.test.mjs tests\\node\\settings_page_split_helpers.test.mjs tests\\node\\renderer_esm_boundary.test.mjs tests\\node\\button_feedback.test.mjs",
    "build": "electron-builder --config electron-builder.yml",
    "build:win": "electron-builder --config electron-builder.yml --win portable nsis --publish never",
    "build:portable": "electron-builder --config electron-builder.yml --win portable --publish never",
    "build:installer": "electron-builder --config electron-builder.yml --win nsis --publish never",
    "build:msi": "electron-builder --config electron-builder.yml --win msi --publish never",
    "build:release": "electron-builder --config electron-builder.yml --win portable nsis --publish never",
    "release:local": "electron-builder --config electron-builder.yml --win portable nsis --publish never",
    "release:notes": "python scripts/generate_release_notes.py",
    "pack": "electron-builder --config electron-builder.yml --dir"
  },
  "author": "Dxj",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "iconv-lite": "^0.7.2"
  }
}
